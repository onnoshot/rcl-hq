/* ====================================================================
   COLOR HARDENING - last in source so it wins ties. Every selector is
   ID-scoped (specificity >= 1,0,1) so it beats any host-theme element/
   class rule even with !important (themes almost never use IDs). Keeps
   every RCL text readable no matter how aggressive the theme CSS is.
   ==================================================================== */
#rcl-fnd-{{ section.id }} h1,#rcl-fnd-{{ section.id }} h2,#rcl-fnd-{{ section.id }} h3,#rcl-fnd-{{ section.id }} h4,#rcl-fnd-{{ section.id }} h5,#rcl-fnd-{{ section.id }} h6,#rcl-fnd-{{ section.id }} p,#rcl-fnd-{{ section.id }} span,#rcl-fnd-{{ section.id }} a,#rcl-fnd-{{ section.id }} li,#rcl-fnd-{{ section.id }} div,#rcl-fnd-{{ section.id }} label,#rcl-fnd-{{ section.id }} small,#rcl-fnd-{{ section.id }} b,#rcl-fnd-{{ section.id }} strong,#rcl-fnd-{{ section.id }} em,#rcl-fnd-{{ section.id }} button,#rcl-fnd-{{ section.id }} input{-webkit-text-fill-color:currentColor!important;}
/* ink (primary) broad default */
#rcl-fnd-{{ section.id }} h1,#rcl-fnd-{{ section.id }} h2,#rcl-fnd-{{ section.id }} h3,#rcl-fnd-{{ section.id }} h4,#rcl-fnd-{{ section.id }} h5,#rcl-fnd-{{ section.id }} h6,#rcl-fnd-{{ section.id }} p,#rcl-fnd-{{ section.id }} span,#rcl-fnd-{{ section.id }} a,#rcl-fnd-{{ section.id }} li,#rcl-fnd-{{ section.id }} div,#rcl-fnd-{{ section.id }} label,#rcl-fnd-{{ section.id }} small,#rcl-fnd-{{ section.id }} b,#rcl-fnd-{{ section.id }} strong,#rcl-fnd-{{ section.id }} em,#rcl-fnd-{{ section.id }} button,#rcl-fnd-{{ section.id }} input{color:var(--ink)!important;}
#rcl-fnd-{{ section.id }} .field input::placeholder{color:color-mix(in srgb,var(--ink) 42%,transparent)!important;-webkit-text-fill-color:color-mix(in srgb,var(--ink) 42%,transparent)!important;}
/* muted */
#rcl-fnd-{{ section.id }} .hl,#rcl-fnd-{{ section.id }} .qsub,#rcl-fnd-{{ section.id }} .rsub,#rcl-fnd-{{ section.id }} .lede,#rcl-fnd-{{ section.id }} .opt .os,#rcl-fnd-{{ section.id }} .rwhy,#rcl-fnd-{{ section.id }} .cat p,#rcl-fnd-{{ section.id }} .item .a-in,#rcl-fnd-{{ section.id }} .ring .pl,#rcl-fnd-{{ section.id }} .mbadge span,#rcl-fnd-{{ section.id }} .hmeta span,#rcl-fnd-{{ section.id }} .ascanl{color:var(--mut)!important;}
/* accent */
#rcl-fnd-{{ section.id }} .pill,#rcl-fnd-{{ section.id }} .qcount,#rcl-fnd-{{ section.id }} .qmulti,#rcl-fnd-{{ section.id }} .sm,#rcl-fnd-{{ section.id }} .rbrand,#rcl-fnd-{{ section.id }} .cat .go,#rcl-fnd-{{ section.id }} .hint,#rcl-fnd-{{ section.id }} .mbadge b,#rcl-fnd-{{ section.id }} .pm,#rcl-fnd-{{ section.id }} .eyebrow,#rcl-fnd-{{ section.id }} .rmchip{color:var(--ac)!important;}
/* option icon uses its per-answer hue */
#rcl-fnd-{{ section.id }} .opt .oic{color:var(--oh,var(--ac))!important;}
/* text on filled (dark/accent) backgrounds */
#rcl-fnd-{{ section.id }} .pbtn,#rcl-fnd-{{ section.id }} .rc .vbtn,#rcl-fnd-{{ section.id }} .rank{color:var(--bg)!important;}
#rcl-fnd-{{ section.id }} .startbtn{color:#fff!important;}
#rcl-fnd-{{ section.id }} .sbtn{color:var(--ink)!important;}
#rcl-fnd-{{ section.id }} .rc.best .rank,#rcl-fnd-{{ section.id }} .chip.sel,#rcl-fnd-{{ section.id }} .opt.sel .oic,#rcl-fnd-{{ section.id }} .opt .ok{color:#fff!important;}
/* Kill any host-theme gradient-heading effect: themes that do
   `h2{background:<gradient>;-webkit-background-clip:text;-webkit-text-fill-color:transparent}`
   make our titles invisible. Force solid ink fill on every heading. */
#rcl-fnd-{{ section.id }} h1,#rcl-fnd-{{ section.id }} h2,#rcl-fnd-{{ section.id }} h3,#rcl-fnd-{{ section.id }} h4,#rcl-fnd-{{ section.id }} h5,#rcl-fnd-{{ section.id }} h6{background:none!important;background-image:none!important;-webkit-background-clip:border-box!important;background-clip:border-box!important;-webkit-text-fill-color:var(--ink)!important;}
/* Re-establish OUR gradient on the last hero word only (higher specificity beats the reset). */
#rcl-fnd-{{ section.id }} h1.htl .w:last-child{background:linear-gradient(100deg,var(--ac),color-mix(in srgb,var(--ac) 42%,var(--ink)))!important;-webkit-background-clip:text!important;background-clip:text!important;-webkit-text-fill-color:transparent!important;}
