    var hu=img(hero.image,720); hu+=(hu.indexOf("?")>=0?"&":"?")+"rclshare="+SID;
    var photoP=safe?Promise.resolve(null):loadImg(hu);
    var logoP=D.share_logo?loadImg(D.share_logo):Promise.resolve(null); // data URI -> taint yok
