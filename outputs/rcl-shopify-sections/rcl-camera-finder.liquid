      cen(S.try_sub,pY+212,"500 26px "+FONT,MUT);
      x.font="800 30px "+FONT;var uw=x.measureText(S.try_cta).width+76;
      x.save();x.shadowColor=rgba(.55);x.shadowBlur=34;x.shadowOffsetY=12;
