        source:"shopify",page:(window.location&&window.location.pathname)||""};
      fetch(D.log_url,{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify(payload),keepalive:true}).catch(function(){});
    }catch(e){}
