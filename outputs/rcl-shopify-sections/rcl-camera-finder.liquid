  var FONT="-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif";
  // 9:16 (1080x1920) minimalist, ortalanmis hikaye gorseli: RCL logo + en uyumlu kamera + teste tesvik.
