 function drawDonut(top,rest){var box=$('#tc-donut');var total=top.concat(rest).reduce(function(a,b){return a+b.count},0)||1;
  var others=rest.reduce(function(a,b){return a+b.count},0);var data=top.map(function(b){return{n:b.brand,v:b.count}});if(others)data.push({n:'Di\u011fer',v:others});
  var sh=['#0a0a0b','#3a3a42','#5c5c66','#7a7a85','#9a9aa3','#b8b8bf','#d2d2d8','#e2e2e7'];
  var C=2*Math.PI*60,off=0,segs='',leg='';
  data.forEach(function(d,i){var frac=d.v/total;var len=frac*C;var col=sh[i%sh.length];
   segs+='<circle class="seg" r="60" cx="85" cy="85" fill="none" stroke="'+col+'" stroke-width="26" stroke-dasharray="'+len.toFixed(2)+' '+(C-len).toFixed(2)+'" stroke-dashoffset="'+(-off).toFixed(2)+'" transform="rotate(-90 85 85)" data-dash="'+len.toFixed(2)+'"></circle>';
   leg+='<div class="lr"><span class="sw" style="background:'+col+'"></span><b>'+esc(d.n)+'</b><span>'+d.v+'</span></div>';off+=len});
  box.innerHTML='<svg class="pie" viewBox="0 0 170 170">'+segs+'<circle r="38" cx="85" cy="85" fill="#fff"/><text x="85" y="80" text-anchor="middle" font-size="22" font-weight="800" fill="#0a0a0b">'+total+'</text><text x="85" y="98" text-anchor="middle" font-size="10" fill="#8a8a93">kamera</text></svg><div class="legend">'+leg+'</div>';
  // animasyon: dash'i 0'dan ac
  var cs=$$('.seg',box);cs.forEach(function(c){var d=c.getAttribute('data-dash');c.style.strokeDasharray='0 '+C;requestAnimationFrame(function(){setTimeout(function(){c.style.transition='stroke-dasharray 1s var(--xo)';c.style.strokeDasharray=d+' '+(C-d)},60)})})}

