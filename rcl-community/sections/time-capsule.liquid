<style>
.tc{--bg:#fff;--bg2:#f6f6f8;--ink:#0a0a0b;--mut:#8a8a93;--bd:#ededf0;--bd2:#e3e3e8;--red:#ff3b30;--blu:#0a84ff;--gd:#0a0a0b;
 --st:linear(0,.006,.025 2.8%,.101 6.1%,.539 18.9%,.721 25.3%,.849,.937 35.8%,.968,.991 45.5%,1.001,1.006 54%,1.003 60.4%,.999 72.5%,1);
 --xo:cubic-bezier(.16,1,.3,1);--bk:cubic-bezier(.34,1.4,.64,1);--sab:env(safe-area-inset-bottom,0px);--sat:env(safe-area-inset-top,0px);
 font-family:-apple-system,'SF Pro Display','SF Pro Text','Segoe UI',sans-serif;color:var(--ink);background:var(--bg);
 -webkit-font-smoothing:antialiased;-webkit-text-size-adjust:100%;touch-action:manipulation;position:relative}
.tc *{box-sizing:border-box}
.tc button{-webkit-tap-highlight-color:transparent;font-family:inherit;cursor:pointer;color:inherit}
.tc svg{display:block}
.tc .ic{width:22px;height:22px;fill:none;stroke:currentColor;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}
.tc .wrap{max-width:935px;margin:0 auto;padding:0 16px}
.tc .rv{opacity:0;transform:translateY(16px);transition:opacity .55s var(--xo),transform .55s var(--xo)}
.tc .rv.in{opacity:1;transform:none}
/* ===== BOOT SPLASH (logo herkese, her acilista + gecislerde) ===== */
.tc .splash{position:fixed;inset:0;z-index:120;background:radial-gradient(130% 60% at 50% 42%,#eef1ff,#fff 70%);display:flex;align-items:center;justify-content:center;transition:opacity .55s var(--xo),visibility .55s}
.tc .splash.hide{opacity:0;visibility:hidden;pointer-events:none}
.tc .splash .smk svg{width:108px;height:108px;overflow:visible}
.tc .splash .smk .track{opacity:.5}
.tc .splash .smk .arc{transform-box:fill-box;transform-origin:center;animation:spin 1.5s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.tc .splash .smk .lgo{color:var(--ink);fill:none;stroke:var(--ink);stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round;transform-box:fill-box;transform-origin:center;animation:lgoin .8s var(--st) both,breathe 2.8s ease-in-out 1.1s infinite}
@keyframes lgoin{0%{transform:scale(.3) rotate(-45deg);opacity:0}60%{opacity:1}100%{transform:scale(1) rotate(0);opacity:1}}
@keyframes breathe{0%,100%{transform:scale(1)}50%{transform:scale(1.07)}}
@media(prefers-reduced-motion:reduce){.tc .splash .arc,.tc .splash .lgo{animation:none!important}.tc .splash .lgo{opacity:1}}
/* ===== AKTIF FILTRE CUBUGU ===== */
.tc .filters{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin:2px 0 14px}
.tc .filters:empty{display:none}
.tc .fchip{display:inline-flex;align-items:center;gap:8px;background:var(--ink);color:#fff;border:0;border-radius:999px;padding:7px 8px 7px 13px;font-size:13px;font-weight:700;animation:fpop .28s var(--bk)}
.tc .fchip .fl{opacity:.62;font-weight:600}.tc .fchip .fx{width:19px;height:19px;border-radius:50%;background:rgba(255,255,255,.22);display:flex;align-items:center;justify-content:center}.tc .fchip .fx .ic{width:12px;height:12px;stroke:#fff;stroke-width:2.6}
@keyframes fpop{from{opacity:0;transform:scale(.8)}to{opacity:1;transform:none}}
.tc .fcount{font-size:12.5px;color:var(--mut);font-weight:600;margin-left:auto;white-space:nowrap}
/* ===== INTRO 3-page onboarding ===== */
.tc .intro{min-height:100dvh;display:flex;flex-direction:column;padding:calc(14px + var(--sat)) 0 calc(22px + var(--sab));position:relative;overflow:hidden;background:radial-gradient(130% 55% at 50% 0%,#eef1ff,#fff 62%)}
.tc .intro .ihead{display:flex;align-items:center;justify-content:space-between;padding:6px 20px}
