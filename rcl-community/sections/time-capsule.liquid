.tc .intro .logo .cap{font-weight:800}
.tc .intro .logo .lg{display:inline-flex;color:var(--ink)}.tc .intro .logo .lg .ic{width:20px;height:20px;stroke-width:1.5}
.tc .intro .skip{border:0;background:0;color:var(--mut);font-size:14px;font-weight:600}
.tc .intro .vp{flex:1;overflow:hidden;display:flex;align-items:center}
.tc .intro .slides{display:flex;width:100%;transition:transform .5s var(--xo)}
.tc .intro .slide{flex:none;width:100%;padding:0 26px;text-align:center;display:flex;flex-direction:column;align-items:center;justify-content:center}
.tc .intro .tc-scene{width:280px!important;max-width:78vw!important;margin:0 auto 6px!important;flex:none!important}
.tc .intro .tc-scene svg{display:block!important;width:100%!important;height:auto!important;max-width:280px!important;max-height:230px!important;overflow:hidden}
.tc .intro h2{font-size:clamp(23px,5.8vw,33px);font-weight:800;letter-spacing:-.03em;margin:24px 0 0}
.tc .intro p{color:var(--mut);font-size:15px;line-height:1.55;max-width:min(390px,86vw);margin:12px auto 0}
.tc .intro .dots{display:flex;gap:8px;justify-content:center;margin:20px 0 16px}
.tc .intro .dots i{width:8px;height:8px;border-radius:50%;background:var(--bd2);cursor:pointer;transition:.3s var(--bk)}
.tc .intro .dots i.on{background:var(--ink);width:22px;border-radius:5px}
.tc .intro .cta{margin:0 20px;background:var(--ink);color:#fff;font-size:16px;font-weight:700;border:0;border-radius:15px;padding:16px;display:flex;align-items:center;justify-content:center;gap:8px;transition:transform .15s var(--bk)}
.tc .intro .cta:active{transform:scale(.97)}.tc .intro .cta .ic{stroke:#fff;width:18px;height:18px}
/* ortak sahne ogeleri - app dili, akici & minimal (cogu hareket translate = iOS guvenli) */
.tc .intro .tc-scene text{font-family:inherit}
.tc .intro .tc-scene .card{fill:#fff;stroke:var(--ink);stroke-width:3;stroke-linejoin:round}
.tc .intro .tc-scene .lens{fill:none;stroke:var(--mut);stroke-width:2.6}.tc .intro .tc-scene .lens2{fill:none;stroke:var(--mut);stroke-width:2}
.tc .intro .tc-scene .bar{fill:var(--bd2)}
.tc .intro .tc-scene .soft{fill:var(--bg2)}
/* scene 1: kesfet (kartlar nazikce suzulur) */
.tc .sc1 .c-l{animation:s1l 5s ease-in-out infinite}
.tc .sc1 .c-r{animation:s1r 5.4s ease-in-out infinite}
.tc .sc1 .c-c{animation:s1c 4.2s ease-in-out infinite}
@keyframes s1l{0%,100%{transform:translateY(2px)}50%{transform:translateY(-7px)}}
@keyframes s1r{0%,100%{transform:translateY(-5px)}50%{transform:translateY(5px)}}
@keyframes s1c{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
.tc .sc1 .badge{transform-box:fill-box;transform-origin:center;animation:s1b 4.2s ease-in-out infinite}
.tc .sc1 .badge rect{fill:var(--ink)}.tc .sc1 .badge text{fill:#fff;font-size:11px;font-weight:800}
@keyframes s1b{0%,40%,100%{transform:scale(1)}48%{transform:scale(1.18)}}
/* scene 2: begen & sirala (ici bos kalp + dolu kalp atisla belirir) */
.tc .sc2 .hbase{fill:none;stroke:var(--red);stroke-width:3;stroke-linejoin:round}
.tc .sc2 .hfill{fill:var(--red);transform-box:fill-box;transform-origin:center;animation:s2h 2.8s ease-in-out infinite}
@keyframes s2h{0%,10%{transform:scale(0);opacity:0}26%{transform:scale(1.18);opacity:1}40%{transform:scale(1)}82%{transform:scale(1);opacity:1}94%,100%{transform:scale(0);opacity:0}}
.tc .sc2 .rank{animation:s2r 2.8s ease-in-out infinite}
.tc .sc2 .rank rect{fill:var(--ink)}.tc .sc2 .rank text{fill:#fff;font-size:11px;font-weight:800}
@keyframes s2r{0%,100%{transform:translateY(9px);opacity:0}40%,76%{transform:translateY(0);opacity:1}}
.tc .sc2 .thumb{animation:s2t 4.4s ease-in-out infinite}
.tc .sc2 .thumb rect{fill:#fff;stroke:var(--ink);stroke-width:2.6}.tc .sc2 .thumb circle{fill:var(--mut)}.tc .sc2 .thumb path{fill:none;stroke:var(--mut);stroke-width:2.2;stroke-linecap:round;stroke-linejoin:round}
@keyframes s2t{0%{transform:translate(-26px,-14px);opacity:0}26%{opacity:1}52%{transform:translate(0,0);opacity:1}100%{transform:translate(0,0);opacity:1}}
/* scene 3: gorev & odul (bar KIRMIZIDAN YESILE dolar -> rozet -> kupon) */
.tc .sc3 .ptrack{fill:var(--bd2)}
.tc .sc3 .pfill{transform-box:fill-box;transform-origin:left center;animation:s3p 4.4s var(--xo) infinite}
@keyframes s3p{0%{transform:scaleX(0)}40%,100%{transform:scaleX(1)}}
.tc .sc3 .medal{transform-box:fill-box;transform-origin:center;animation:s3m 4.4s ease-in-out infinite}
.tc .sc3 .medal circle{fill:#34c759}
.tc .sc3 .chk{fill:none;stroke:#fff;stroke-width:3;stroke-linecap:round;stroke-linejoin:round}
@keyframes s3m{0%,40%{transform:scale(0);opacity:0}50%{transform:scale(1.16);opacity:1}60%{transform:scale(1)}100%{transform:scale(1);opacity:1}}
.tc .sc3 .spk{transform-box:fill-box;transform-origin:center;animation:s3s 4.4s ease-in-out infinite}.tc .sc3 .spk path{fill:#34c759}.tc .sc3 .s2{animation-delay:.1s}.tc .sc3 .s3{animation-delay:.05s}
@keyframes s3s{0%,48%{opacity:0;transform:scale(.3)}58%{opacity:1;transform:scale(1)}80%,100%{opacity:0;transform:scale(.6)}}
.tc .sc3 .ticket{animation:s3t 4.4s ease-in-out infinite}
.tc .sc3 .ticket rect{fill:#fff;stroke:var(--ink);stroke-width:3}.tc .sc3 .ticket line{stroke:var(--ink);stroke-width:2;stroke-dasharray:3 3}.tc .sc3 .ticket text{fill:var(--ink);font-size:15px;font-weight:800}
@keyframes s3t{0%,58%{transform:translateY(22px);opacity:0}72%,100%{transform:translateY(0);opacity:1}}
@media(prefers-reduced-motion:reduce){.tc .intro .tc-scene *{animation:none!important}.tc .sc2 .hfill{transform:scale(1);opacity:1}.tc .sc3 .pfill{transform:scaleX(1)}.tc .sc3 .medal{transform:scale(1);opacity:1}.tc .sc3 .ticket{opacity:1;transform:none}}
/* ===== APP ===== */
.tc .top{position:static;background:var(--bg);border-bottom:1px solid var(--bd)}
.tc .top .inner{max-width:935px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding:10px 16px}
.tc .brandmark{font-size:16px;font-weight:500;letter-spacing:-.01em;color:var(--ink);display:flex;align-items:center;gap:8px}
.tc .brandmark .cap{font-weight:800}
.tc .brandmark .lg{width:22px;height:22px;color:var(--ink);flex:none}.tc .brandmark .lg .ic{width:22px;height:22px;stroke-width:1.5}
.tc .topr{display:flex;gap:8px}
.tc .iconbtn{width:36px;height:36px;border-radius:50%;border:1px solid var(--bd2);background:var(--bg);display:flex;align-items:center;justify-content:center;color:var(--mut)}.tc .iconbtn .ic{width:18px;height:18px}.tc .iconbtn:active{transform:scale(.94)}
/* floating Apple-tarzi alt nav (yuzen kapsul) */
.tc .bnav{position:fixed;left:50%;transform:translateX(-50%);bottom:calc(13px + var(--sab));z-index:35;width:calc(100% - 26px);max-width:430px;background:rgba(255,255,255,.7);backdrop-filter:blur(26px) saturate(1.8);-webkit-backdrop-filter:blur(26px) saturate(1.8);border:.5px solid rgba(0,0,0,.07);box-shadow:0 10px 34px -10px rgba(0,0,0,.22),0 1px 0 rgba(255,255,255,.7) inset;border-radius:26px;display:flex;justify-content:space-around;padding:6px 7px}
.tc .bnav button{flex:1;border:0;background:0;display:flex;flex-direction:column;align-items:center;gap:3px;color:var(--mut);font-size:9.5px;font-weight:600;letter-spacing:.01em;padding:7px 4px 6px;border-radius:17px;min-height:46px;transition:color .22s,background .28s var(--xo)}
.tc .bnav button .ic{width:23px;height:23px;transition:transform .32s var(--bk),stroke-width .2s}
.tc .bnav button:active .ic{transform:scale(.88)}
.tc .bnav button.on{color:var(--ink);background:rgba(10,10,11,.055)}
.tc .bnav button.on .ic{stroke-width:2.2;transform:translateY(-1px)}
.tc .page{padding-bottom:108px}
/* hero */
.tc .hero{text-align:center;padding:30px 0 10px}
.tc .hero h2{font-size:clamp(26px,6vw,42px);font-weight:500;letter-spacing:-.04em;margin:0}.tc .hero h2 .cap{font-weight:800}
.tc .hero .tg{color:var(--ink);font-size:15px;font-weight:700;letter-spacing:.01em;margin:10px 0 0}
.tc .hero .habout{max-width:min(560px,86vw);margin:14px auto 0;color:var(--mut);font-size:13.5px;line-height:1.65;text-align:center}
/* kamera arama */
.tc .csearch{position:relative;display:flex;align-items:center;margin:0 0 12px}
.tc .csearch .si{position:absolute;left:13px;color:var(--mut);pointer-events:none;display:flex}.tc .csearch .si .ic{width:18px;height:18px}
.tc .csearch input{width:100%;border:1px solid var(--bd2);border-radius:13px;background:var(--bg2);font-size:16px;padding:12px 40px;font-family:inherit;outline:none;color:var(--ink);transition:.18s}
.tc .csearch input:focus{border-color:var(--ink);background:var(--bg)}
.tc .csearch input::-webkit-search-cancel-button,.tc .csearch input::-webkit-search-decoration{-webkit-appearance:none;display:none}
.tc .csearch .cx{position:absolute;right:8px;width:28px;height:28px;border:0;background:var(--bd2);border-radius:50%;display:none;align-items:center;justify-content:center;color:var(--ink)}.tc .csearch .cx .ic{width:13px;height:13px;stroke-width:2.4}.tc .csearch.has .cx{display:flex}
/* section head + sort */
.tc .sh{display:flex;align-items:center;justify-content:space-between;margin:26px 0 12px;gap:10px}
.tc .sh h3{font-size:19px;font-weight:800;letter-spacing:-.02em;margin:0}
.tc .sortbar{display:flex;gap:8px;align-items:center;overflow-x:auto;padding:2px 0 14px;scrollbar-width:none}
.tc .sortbar::-webkit-scrollbar{display:none}
.tc .sortbar .si{color:var(--mut);flex:none}.tc .sortbar .si .ic{width:20px;height:20px}
.tc .chip{flex:none;border:1px solid var(--bd2);background:var(--bg);color:var(--ink);font-size:13px;font-weight:600;padding:8px 14px;border-radius:999px;white-space:nowrap;transition:.18s var(--xo)}
.tc .chip.on{background:var(--ink);color:#fff;border-color:var(--ink)}
.tc .chips{display:flex;gap:8px;overflow-x:auto;padding:0 0 14px;scrollbar-width:none}.tc .chips::-webkit-scrollbar{display:none}
/* camera grid */
.tc .cams{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:16px}
@media(max-width:640px){.tc .cams{grid-template-columns:repeat(2,1fr);gap:12px}}
.tc .cam{background:var(--bg);border:1px solid var(--bd);border-radius:16px;overflow:hidden;cursor:pointer;transition:transform .22s var(--xo),box-shadow .28s;content-visibility:auto;contain-intrinsic-size:auto 290px}
.tc .cam:active{transform:scale(.985)}
@media(hover:hover){.tc .cam:hover{transform:translateY(-3px);box-shadow:0 14px 32px -14px rgba(0,0,0,.2)}}
.tc .cam .im{position:relative;aspect-ratio:4/3;background:var(--bg2);overflow:hidden}
.tc .cam .im img{width:100%;height:100%;object-fit:cover;opacity:0;transition:opacity .5s,transform .5s var(--xo)}
.tc .cam .im img.ld{opacity:1}
@media(hover:hover){.tc .cam:hover .im img{transform:scale(1.04)}}
.tc .cam .bd{padding:11px 13px 12px}
.tc .cam .cr{display:flex;align-items:center;gap:6px;margin-bottom:4px}
.tc .cam .rkc{font-size:10px;font-weight:800;color:#fff;background:var(--ink);border-radius:6px;padding:2px 6px;font-variant-numeric:tabular-nums;flex:none}
