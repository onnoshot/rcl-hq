  if(vis('liked'))html+=secCard(T.likedMine,voted.length,voted.length?'<div class="crow">'+voted.map(camMini).join('')+'</div>':'','-');
  if(vis('wait'))html+=secCard(T.waitMine,wait.length,wait.length?'<div class="crow">'+wait.map(camMini).join('')+'</div>':'','-');
  if(vis('cams')){var camsInner=(mycams.length?'<div class="mycams">'+mycams.map(function(c){return '<span class="mycam"><b>'+esc(c.brand)+'</b> '+esc(c.model)+(own?' <span class="rm" data-rmcam="'+c.id+'">&#215;</span>':'')+'</span>'}).join('')+'</div>':'')+(own?'<button class="btn sec" id="tc-addcampick" style="width:auto;margin-top:'+(mycams.length?'12':'2')+'px;padding:11px 16px">'+I('plus')+esc(T.addCamPick)+'</button>':'');
   html+=secCard(T.myCams,mycams.length,camsInner,'-');}
  if(vis('photos'))html+=secCard(T.memberPhotos,photos.length,photos.length?'<div class="pf-grid">'+photos.map(function(ph){return '<img loading="lazy" src="'+esc(ph.image_url)+'">'}).join('')+'</div>':'',T.noPhotos);
  b.innerHTML=html+'</div>'}
 async function addMyCam(){var br=$('#tc-nc-brand').value.trim(),md=$('#tc-nc-model').value.trim();if(!br||!md)return;var r=await api('my-camera',{method:'POST',body:{brand:br,model:md}});if(r&&r.ok){bump('mycams',1);renderProfile(S.profile.handle,S.view==='mine'?$('#tc-mine-in'):$('#tc-pr-body'))}}
 async function rmMyCam(id){var r=await api('my-camera',{method:'POST',body:{action:'remove',id:id}});if(r&&r.ok)renderProfile(S.profile.handle,S.view==='mine'?$('#tc-mine-in'):$('#tc-pr-body'))}
 // ===== profil duzenle (avatar + kullanici adi + isim) =====
 var edAvatar=null;
 function openEdit(){var m=S.me||{},pf=S.profile||{};$('#tc-ed-avimg').src=m.avatar_url||'';$('#tc-ed-name').value=pf.display_name||m.display_name||'';$('#tc-ed-handle').value=pf.handle||m.handle||'';edAvatar=null;
  var lk=m.links||{};SOC.forEach(function(s){var el=$('#tc-ed-link-'+s.k);if(el)el.value=lk[s.k]||''});
  var spv=m.section_prefs||{};['liked','wait','cams','photos'].forEach(function(k){var el=$('#tc-ed-sec-'+k);if(el)el.checked=spv[k]!==false});
  $('#tc-ed-err').classList.remove('show');$('#tc-edit').classList.add('show')}
 async function pickEditAvatar(file){if(!file||!/^image\//.test(file.type))return;var clean=await shrink(file);edAvatar=clean;$('#tc-ed-avimg').src=clean}
 async function saveEdit(){var name=$('#tc-ed-name').value.trim();var handle=$('#tc-ed-handle').value.trim().toLowerCase();var btn=$('#tc-ed-save'),err=$('#tc-ed-err');err.classList.remove('show');
  if(handle&&handle.replace(/[^a-z0-9._]/g,'').length<3){err.textContent=T.unameMin;err.classList.add('show');return}
  var body={};if(name)body.display_name=name;if(handle)body.handle=handle;if(edAvatar)body.avatar=edAvatar;
  var links={};SOC.forEach(function(s){var el=$('#tc-ed-link-'+s.k);var v=el?el.value.trim():'';if(v)links[s.k]=v});body.links=links;
  var spref={};['liked','wait','cams','photos'].forEach(function(k){var el=$('#tc-ed-sec-'+k);if(el&&!el.checked)spref[k]=false});body.section_prefs=spref;
  btn.disabled=true;var r=await api('profile-update',{method:'POST',body:body});btn.disabled=false;
  if(r&&r.ok){var p=r.profile;if(S.profile){S.profile.handle=p.handle;S.profile.display_name=p.display_name;S.profile.avatar_url=p.avatar_url}S.me=p;haptic(12);toast(T.savedW);$('#tc-edit').classList.remove('show');if(S.view==='mine')openProfileInline()}
  else{err.textContent=(r&&r.error)||T.editErr;err.classList.add('show')}}

 function openFb(){$('#tc-fb').classList.add('show');S.fbRating=0;$$('.stars-in span').forEach(function(s){s.classList.remove('on')});$('#tc-fb-msg').value='';$('#tc-fb-form').style.display='';$('#tc-fb-done').style.display='none'}
 async function sendFb(){var msg=$('#tc-fb-msg').value.trim();if(!S.fbRating&&!msg)return;await api('feedback',{method:'POST',body:{rating:S.fbRating,category:$('#tc-fb-cat').value,message:msg}});haptic(12);$('#tc-fb-form').style.display='none';$('#tc-fb-done').style.display=''}

 $$('.sheet').forEach(function(sh){var grab=$('.grab',sh);if(!grab)return;var sy=0,dy=0,drag=false,st=0;
  grab.addEventListener('touchstart',function(e){drag=true;sy=e.touches[0].clientY;st=Date.now();sh.style.transition='none'},{passive:true});
  grab.addEventListener('touchmove',function(e){if(!drag)return;dy=Math.max(0,e.touches[0].clientY-sy);sh.style.transform='translateY('+dy+'px)'},{passive:true});
  grab.addEventListener('touchend',function(){if(!drag)return;drag=false;sh.style.transition='';var v=dy/Math.max(1,Date.now()-st);if(dy>sh.offsetHeight*.3||v>.5)sh.closest('.ov').classList.remove('show');sh.style.transform='';dy=0})});

 root.addEventListener('click',function(e){var t=e.target;
  var nav=t.closest('.bnav button');if(nav){setView(nav.dataset.v);return}
  var srt=t.closest('[data-sort]');if(srt){S.sort=srt.dataset.sort;S.showAll=false;$$('[data-sort]').forEach(function(x){x.classList.toggle('on',x===srt)});loadCams(true);return}
  var ty=t.closest('[data-year]');if(ty){selectYear(ty.dataset.year,ty);return}
  if(t.closest('#tc-brandsbtn')){openBrands();return}
  var cf=t.closest('[data-clearf]');if(cf){clearFilter(cf.dataset.clearf);haptic(6);return}
  var chip=t.closest('[data-b]');if(chip){selectBrand(chip.dataset.b);return}
  var ac=t.closest('[data-addcol]');if(ac){addCol(ac);return}
  var vb=t.closest('[data-vote]');if(vb){e.stopPropagation();vote(vb);return}
  var wb=t.closest('[data-wait]');if(wb){waitToggle(wb);return}
  var lb=t.closest('[data-like]');if(lb){like(lb);return}
  var pm=t.closest('[data-pmenu]');if(pm){openPMenu(pm);return}
  var pv=t.closest('[data-pvis]');if(pv){peVis=pv.dataset.pvis;$$('#tc-pe-vis button').forEach(function(x){x.classList.toggle('on',x===pv)});return}
  if(t.closest('#tc-pe-save')){savePedit();return}
  if(t.closest('#tc-pe-del')){delPedit();return}
  var cb=t.closest('[data-cmt]');if(cb){toggleCm(cb.dataset.cmt);return}
  var cs=t.closest('[data-cs]');if(cs){sendCm(cs.dataset.cs);return}
  var cp=t.closest('[data-copy]');if(cp){copy(cp.dataset.copy);return}
  var ct=t.closest('[data-cam]');if(ct){openCamera(ct.dataset.cam);return}
  var up=t.closest('[data-upcam]');if(up){$('#tc-cam').classList.remove('show');openUpload(up.dataset.upcam);return}
  var who=t.closest('[data-h]');if(who&&who.dataset.h){openProfile(who.dataset.h);return}
  var camEl=t.closest('.cam');if(camEl){openCamera(camEl.dataset.id);return}
  if(t.closest('#tc-seeall')){toggleSeeAll();return}
  if(t.closest('#tc-feedmore')){loadFeed(false);return}
  if(t.closest('#tc-fabup')){openUpload(null);return}
  if(t.closest('#tc-upcam')){openPicker('upload');return}
  if(t.closest('#tc-addcampick')){openPicker('collection');return}
  var vis=t.closest('[data-vis]');if(vis){S.upVis=vis.dataset.vis;$$('#tc-upvis button').forEach(function(x){x.classList.toggle('on',x===vis)});return}
  var pk=t.closest('[data-pick]');if(pk){if(S.pickMode==='collection'){addMyCamPick(pk.dataset.b,pk.dataset.m)}else{setUpCam(pk.dataset.pick,pk.dataset.label)}$('#tc-pick').classList.remove('show');return}
  if(t.closest('#tc-nc-add')){addMyCam();return}
  var rm=t.closest('[data-rmcam]');if(rm){rmMyCam(rm.dataset.rmcam);return}
  if(t.closest('#tc-search-x')){var si=$('#tc-search');si.value='';si.closest('.csearch').classList.remove('has');S.q='';S.showAll=false;loadCams(true);return}
  if(t.closest('#tc-editbtn')||t.closest('#tc-avtap')){openEdit();return}
  if(t.closest('#tc-ed-avbtn')||t.closest('#tc-ed-avbtn2')){$('#tc-ed-avfile').click();return}
  if(t.closest('#tc-ed-save')){saveEdit();return}
  if(t.closest('#tc-fbb')){openFb();return}
  if(t.closest('#tc-topprof')){setView('mine');return}
  if(t.closest('#tc-fb-send')){sendFb();return}
  if(t.closest('#tc-badge-ok')){$('#tc-badge').classList.remove('show');return}
  var star=t.closest('.stars-in span');if(star){S.fbRating=+star.dataset.r;$$('.stars-in span').forEach(function(s){s.classList.toggle('on',+s.dataset.r<=S.fbRating)});return}
  if(t.closest('.x')||t.classList.contains('ov')){var ov=t.closest('.ov');if(ov)ov.classList.remove('show');return}});
 document.addEventListener('keydown',function(e){if(e.key==='Escape'){var open=$$('.ov.show');if(open.length)open[open.length-1].classList.remove('show')}});
 var lastTap=0;root.addEventListener('touchend',function(e){var w=e.target.closest('[data-likeimg]');if(!w)return;var now=Date.now();if(now-lastTap<300){var btn=$('.lk',w.closest('.post'));if(btn){like(btn,true);var d=$('.dbl',w);if(d){d.classList.remove('go');void d.offsetWidth;d.classList.add('go')}}}lastTap=now});
 $('#tc-upfile').addEventListener('change',function(e){pickPhoto(e.target.files[0])});
 $('#tc-ed-avfile').addEventListener('change',function(e){pickEditAvatar(e.target.files[0])});
 var stq;$('#tc-search').addEventListener('input',function(){var v=this.value;this.closest('.csearch').classList.toggle('has',!!v);clearTimeout(stq);stq=setTimeout(function(){S.q=v.trim();S.showAll=false;loadCams(true)},300)});
 $('#tc-updrop').addEventListener('click',function(){$('#tc-upfile').click()});
 $('#tc-up-send').addEventListener('click',submitUp);
 if(!RM){var ex=document.createElement('script');ex.src='https://cdn.jsdelivr.net/npm/exifr/dist/full.umd.js';document.head.appendChild(ex)}
 boot();
