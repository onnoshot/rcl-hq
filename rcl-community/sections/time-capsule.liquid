function initIntroOnly(){var idx=0,n=3,slides=$('#tc-slides'),dots=$$('#tc-dots i'),vp=$('#tc-vp'),ctat=$('#tc-ctat');if(!slides)return;
  function go(i){idx=Math.max(0,Math.min(n-1,i));slides.style.transform='translateX('+(-idx*100)+'%)';dots.forEach(function(d,k){d.classList.toggle('on',k===idx)});ctat.textContent=idx===n-1?T.introCta:T.introNext}
  $('#tc-next').addEventListener('click',function(){slides.style.transition='';if(idx===n-1)location.href=LOGIN;else go(idx+1)});
  $('#tc-skip').addEventListener('click',function(){location.href=LOGIN});
  dots.forEach(function(d,k){d.addEventListener('click',function(){slides.style.transition='';go(k)})});
  var sx=0,dx=0,drag=false;
  vp.addEventListener('touchstart',function(e){sx=e.touches[0].clientX;drag=true;slides.style.transition='none'},{passive:true});
  vp.addEventListener('touchmove',function(e){if(!drag)return;dx=e.touches[0].clientX-sx;slides.style.transform='translateX(calc('+(-idx*100)+'% + '+dx+'px))'},{passive:true});
  vp.addEventListener('touchend',function(){if(!drag)return;drag=false;slides.style.transition='';if(Math.abs(dx)>45)go(idx+(dx<0?1:-1));else go(idx);dx=0});
  go(0)}

