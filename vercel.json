{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/community/stats", "destination": "/api/community/index?action=stats" },
    { "source": "/api/hesabim/community/(.*)", "destination": "/api/community/index?action=$1" }
  ],
  "functions": {
    "api/chat.js": {
      "maxDuration": 25
    },
    "api/shopify-publish.js": {
      "maxDuration": 15
    },
    "api/community/index.js": {
      "maxDuration": 30
    }
  }
}
