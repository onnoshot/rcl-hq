{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/hesabim/community/profil/(.*)",  "destination": "/api/community/index?action=page&type=profil&seg=$1" },
    { "source": "/api/hesabim/community/foto/(.*)",    "destination": "/api/community/index?action=page&type=foto&seg=$1" },
    { "source": "/api/hesabim/community/yarisma/(.*)", "destination": "/api/community/index?action=page&type=yarisma&seg=$1" },
    { "source": "/api/community/moderate", "destination": "/api/community/index?action=moderate" },
    { "source": "/api/community/award",    "destination": "/api/community/index?action=award" },
    { "source": "/api/hesabim/community/(.*)", "destination": "/api/community/index?action=$1" }
  ],
  "functions": {
    "api/chat.js": {
      "maxDuration": 25
    },
    "api/shopify-publish.js": {
      "maxDuration": 15
    },
    "api/community/index.js": {
      "maxDuration": 30
    }
  }
}
